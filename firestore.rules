rules_version = '2';

// =========================================================
// EL TURCO — Reglas de seguridad de Firestore
// Pegá TODO esto en: Firebase Console > Firestore Database > Reglas
// (reemplazando lo que haya) y hacé click en "Publicar".
// =========================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Colección pública: sólo dice qué día/hora está ocupado.
    // No tiene nombres ni teléfonos, por eso es segura de leer
    // para cualquier visitante del sitio.
    match /takenSlots/{slotId} {
      allow read: if true;
      allow create: if true;
      allow update: if false;
      // Sólo el admin logueado (panel de administración) puede
      // borrar un horario ocupado, al cancelar una reserva.
      allow delete: if request.auth != null;
    }

    // Colección con los datos completos de cada reserva
    // (nombre, teléfono, cantidad de jugadores). Se puede CREAR
    // desde el sitio (cuando alguien reserva), pero sólo se puede
    // LEER o CANCELAR estando logueado como admin en el panel
    // (/admin.html). Así los datos de tus clientes quedan
    // protegidos de cualquier visitante común del sitio.
    match /reservations/{reservationId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update: if false;
      allow delete: if request.auth != null;
    }
  }
}
